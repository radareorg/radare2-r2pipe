{
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "target": "esnext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "module": "nodenext",
    "lib": ["esnext"],
    "types": ["node"],
    "declaration": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./r2pipe"
  },
  "include": [
    "r2pipe/**/*.ts"
  ]
}
